# ==============================================
#  CONFIGURAÇÕES OBRIGATÓRIAS (E-MAIL)
# ==============================================

# Seu endereço de e-mail Gmail (aquele que vai enviar as mensagens)
EMAIL_ORIGEM=seuemail@gmail.com

# Para quem enviar o resumo (pode ser o mesmo e-mail acima)
EMAIL_DESTINO=seuemail@gmail.com

# Senha de aplicativo do Gmail (NÃO use sua senha normal)
# Como obter:
# 1. Ative a "Verificação em duas etapas" na sua Conta Google.
# 2. Acesse https://myaccount.google.com/apppasswords
# 3. Selecione "Mail" e "Outro (nome personalizado)".
# 4. Copie a senha de 16 caracteres gerada (formato: xxxx xxxx xxxx xxxx).
# 5. Cole abaixo, sem espaços (ou com espaços, tanto faz).
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop 


# ==============================================
#  CONFIGURAÇÕES OPCIONAIS (NOTÍCIAS)
# ==============================================

# Chave da API do NewsAPI (gratuita até 100 requisições/dia)
# Como obter: cadastre-se em https://newsapi.org/ e copie a chave do dashboard.
NEWS_API_KEY=sua_chave_aqui


# ==============================================
#  CONFIGURAÇÕES OPCIONAIS (IA - GEMINI)
# ==============================================

# Chave da API do Google Gemini (necessária apenas se USAR_IA = True no script)
# Como obter: acesse https://aistudio.google.com/ -> Get API key.
GEMINI_API_KEY=sua_chave_aqui
